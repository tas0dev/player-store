{
	"schemaVersion": 1,
	"id": "playerstore",
	"version": "${version}",
	"name": "PlayerStore",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/playerstore/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "io.github.tas0dev.mc.store.PlayerStore",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "io.github.tas0dev.mc.store.client.PlayerStoreClient",
				"adapter": "kotlin"
			}
		],
		"modmenu": [
			{
				"value": "io.github.tas0dev.mc.store.client.modmenu.PlayerStoreModMenuIntegration",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "io.github.tas0dev.mc.store.client.PlayerStoreDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"playerstore.mixins.json",
		{
			"config": "playerstore.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}
